#lang at-exp racket/base

(require ming ming/list ming/string ming/number net/uri-codec
         racket/format
         "gua-helper.rkt"
         "8gua.rkt"
         "64gua.rkt"
         "senders.rkt"
         "zixuan.rkt")
(provide T1 T2 T3 T4 T5 T6 T7
         VP1 VP2 VP3 VP4 VP5 VP6 VP7 VP8
         E1 E2 E3 E4 E5 E6 E7 E8
         D1 D2 ;;D3 D4
         C1 C2 C3 C4 C5
         B1 B2 B3 B4 B5 B6 B7
         S1 S2 S3 S4 S5 S6 S7
         R1 R2 R3 R4 R5
         )

;; 􏵞: 0707，0706，0705，0704，0703。通常需要逆序，亦即(􏾛 􏵞)
(名 (价米 H)
    (􏿰弔 H 'p8gua-n))
(名 (量米 H)
    (􏿰弔 H 'v8gua-n))
(名 (价精米 H)
    (􏿰弔 H 'pgua-n))
(名 (量精米 H)
    (􏿰弔 H 'vgua-n))
(名 (价跃 H)
    (􏿰弔 H 'p8gua-tn))
(名 (量跃 H)
    (􏿰弔 H 'v8gua-tn))
(名 (价精跃 H)
    (􏿰弔 H 'pgua-tn))
(名 (量精跃 H)
    (􏿰弔 H 'vgua-tn))

;; Trend States（趋势状态）
(名 (T1 L)
    (并 (>= (价跃 (􏷜 L)) 1)
        (>= (价跃 (􏷛 L)) 1)
        (>= (价跃 (􏷚 L)) 1)))
(名 (T2 L)
    (并 (<= (价跃 (􏷜 L)) -1)
        (<= (价跃 (􏷛 L)) -1)
        (<= (价跃 (􏷚 L)) -1)))
(名 (T3 L)
    (并 (<= (􏹚 (价跃 (􏷜 L))) 1)
        (<= (􏹚 (价跃 (􏷛 L))) 1)
        (<= (􏹚 (价跃 (􏷚 L))) 1)
        (<= (􏹚 (价跃 (􏷙 L))) 1)
        (<= (􏹚 (价跃 (􏷘 L))) 1)))
(名 (T4 L)
    (并 (T3 (阴 L))
        (>= (价跃 (􏷜 L)) 2)))
(名 (T5 L)
    (并 (T3 (阴 L))
        (<= (价跃 (􏷜 L)) -2)))
(名 (T6 L)
    (并 (> (价米 (􏷜 L)) (价米 (􏷛 L)) (价米 (􏷚 L)))
        (>= (/ (+ (量米 (􏷜 L))
                  (量米 (􏷛 L))
                  (量米 (􏷚 L))) 3)
            4)))
(名 (T7 L)
    (并 (< (价米 (􏷜 L)) (价米 (􏷛 L)) (价米 (􏷚 L)))
        (>= (/ (+ (量米 (􏷜 L))
                  (量米 (􏷛 L))
                  (量米 (􏷚 L))) 3)
            4)))

;; 量价关系状态（Price-Volume States）
(名 (VP1 L)
    (名 H (􏷜 L))
    (并 (>= (价跃 H) 1)
        (>= (量跃 H) 2)))
(名 (VP2 L)
    (名 H (􏷜 L))
    (并 (>= (价跃 H) 1)
        (<= (量跃 H) 0)))
(名 (VP3 L)
    (名 H (􏷜 L))
    (并 (<= (价跃 H) -1)
        (>= (量跃 H) 2)))
(名 (VP4 L)
    (名 H (􏷜 L))
    (并 (<= (价跃 H) -1)
        (<= (量跃 H) 0)))
(名 (VP5 L)
    (名 H (􏷜 L))
    (并 (= (价跃 H) 0)
        (>= (量米 H) 6)))
(名 (VP6 L)
    (名 H (􏷜 L))
    (并 (= (价跃 H) 0)
        (>= (量米 H) 6)))
(名 (VP7 L)
    (名 H (􏷜 L))
    (并 (= (价跃 H) 0)
        (<= (量米 H) 2)))
(名 (VP8 L)
    (名 H (􏷜 L))
    (并 (>= (价跃 H) 2)
        (>= (量跃 H) 3)))

;; 极值状态（Extreme States）
(名 (E1 L)
    (= (价米 (􏷜 L)) 7))
(名 (E2 L)
    (= (价米 (􏷜 L)) 0))
(名 (E3 L)
    (= (量米 (􏷜 L)) 7))
(名 (E4 L)
    (= (量米 (􏷜 L)) 0))
(名 (E5 L)
    (>= (价米 (􏷜 L)) 6))
(名 (E6 L)
    (<= (价米 (􏷜 L)) 1))
(名 (E7 L)
    (>= (量米 (􏷜 L)) 6))
(名 (E8 L)
    (<= (量米 (􏷜 L)) 1))


;; 背离状态（Divergence States）
(名 (D1 L)
    (名 H (􏷜 L))
    (并 (> (价跃 H) 0)
        (> (量跃 H) 0)
        (>= (价米 H) 5)))
(名 (D2 L)
    (名 H (􏷜 L))
    (并 (< (价跃 H) 0)
        (> (量跃 H) 0)
        (<= (价米 H) 2)))

;; 压缩状态（Compression States）
(名 (C1 L)
    (并 (并 (<= (价米 (􏷜 L)) 2) (<= (􏹚 (价跃 (􏷜 L))) 1))
        (并 (<= (价米 (􏷛 L)) 2) (<= (􏹚 (价跃 (􏷛 L))) 1))
        (并 (<= (价米 (􏷚 L)) 2) (<= (􏹚 (价跃 (􏷚 L))) 1))
        (并 (<= (价米 (􏷙 L)) 2) (<= (􏹚 (价跃 (􏷙 L))) 1))
        (并 (<= (价米 (􏷘 L)) 2) (<= (􏹚 (价跃 (􏷘 L))) 1))))
(名 (C2 L)
    (并 (>= (价米 (􏷜 L)) 5)
        (>= (价米 (􏷛 L)) 5)
        (>= (价米 (􏷚 L)) 5)))
(名 (C3 L)
    (并 (<= (价米 (􏷜 L)) 2)
        (<= (价米 (􏷛 L)) 2)
        (<= (价米 (􏷚 L)) 2)))
(名 (C4 L)
    (并 (> (量米 (􏷜 L)) (量米 (􏷛 L)) (量米 (􏷚 L)))
        (= (价米 (􏷜 L)) (价米 (􏷛 L)) (价米 (􏷚 L)))))
(名 (C5 L)
    (并 (< (量米 (􏷜 L)) (量米 (􏷛 L)) (量米 (􏷚 L)))
        (= (价米 (􏷜 L)) (价米 (􏷛 L)) (价米 (􏷚 L)))))

;; 买入信号（Buy Signals）
(名 (B1 L)
    (并 (E2 L)
        (VP1 L)))
(名 (B2 L)
    (并 (T4 L)
        (VP1 L)))
(名 (B3 L)
    (并 (D2 L)
        (VP1 L)))
(名 (B4 L)
    (并 (T1 L)
        (VP4 L)))
(名 (B5 L)
    (并 (E6 L)
        (VP1 L)))
(名 (B6 L)
    (并 (C1 L)
        (VP8 L)))
(名 (B7 L)
    (并 (E1 L)
        (VP8 L)))

;; 卖出信号（Sell Signals）
(名 (S1 L)
    (并 (>= (价米 (􏷜 L)) 6)
        (>= (量米 (􏷜 L)) 6)))
(名 (S2 L) (D1 L))
(名 (S3 L)
    (并 (T5 L)
        (VP3 L)))
(名 (S4 L)
    (VP5 L))
(名 (S5 L)
    (并 (C2 L)
        (VP5 L)))
(名 (S6 L)
    (并 (E3 L)
        (E5 L)))
(名 (S7 L)
    (并 (T5 L)
        (T1 (􏷴 L 6))))

;; 风险等级（Risk Levels）
(名 (R1 L)
    (并 (非 (R2 L))
        (非 (R3 L))
        (非 (R4 L))
        (非 (R5 L))))
(名 (R2 L)
    (戈 (E1 L)
        (E2 L)
        (C1 L)))
(名 (R3 L)
    (戈 (D1 L)
        (D2 L)
        (C2 L)))
(名 (R4 L)
    (戈 (VP3 L)
        (T5 L)))
(名 (R5 L)
    (戈 (S1 L)
        (S6 L)))
